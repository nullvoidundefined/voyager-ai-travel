# Server proxy target (server-only, NOT embedded in the browser bundle).
# Set this in Railway instead of NEXT_PUBLIC_API_URL for production deployments.
API_URL=

# Fallback API URL for local development (also used as proxy if API_URL is not set).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public app URL used in sitemap.ts and robots.ts.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps JavaScript API key (Maps JavaScript API must be enabled in GCP).
# Same GCP project as GOOGLE_PLACES_API_KEY on the server side.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Mapbox token used by TripMap for map rendering.
NEXT_PUBLIC_MAPBOX_TOKEN=
