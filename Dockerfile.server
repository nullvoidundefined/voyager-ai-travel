FROM node:22-slim AS base
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /app

# Copy workspace config
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

# Copy server and shared-types package.json for dependency resolution
COPY apps/server/package.json apps/server/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json

# Install dependencies (production + dev for build)
RUN pnpm install --frozen-lockfile --filter voyager-server --filter @voyager/shared-types --ignore-scripts

# Copy server source and shared-types
COPY apps/server/ apps/server/
COPY packages/shared-types/ packages/shared-types/

# Build shared-types first so its dist/ exists when the server compiles + runs
RUN pnpm --filter @voyager/shared-types run build
RUN pnpm --filter voyager-server run build

# Production stage
FROM node:22-slim AS production
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY apps/server/package.json apps/server/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json
RUN pnpm install --frozen-lockfile --filter voyager-server --ignore-scripts --prod

COPY --from=base /app/packages/shared-types/dist packages/shared-types/dist
COPY --from=base /app/apps/server/dist apps/server/dist
COPY apps/server/src/data/destinations.json apps/server/dist/data/destinations.json
COPY apps/server/migrations apps/server/migrations

EXPOSE 3001
USER node
CMD ["node", "apps/server/dist/index.js"]
