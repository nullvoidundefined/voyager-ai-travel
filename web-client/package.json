{
  "name": "voyager-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --config ../eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config ../eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config ../prettier.config.bottomlessmargaritas.mjs --write .",
    "format:check": "prettier --config ../prettier.config.bottomlessmargaritas.mjs --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/analytics": "^1",
    "@vercel/speed-insights": "^2.0.0",
    "@voyager/shared-types": "workspace:*",
    "next": "15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "sass": "^1.86.0",
    "vibelens": "^2.1.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.0.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.3",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
