{
  "name": "agentic-travel-agent",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter agentic-travel-agent-server build && pnpm --filter agentic-travel-agent-web build",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "test": "pnpm --filter agentic-travel-agent-server run test",
    "test:coverage": "pnpm --filter agentic-travel-agent-server run test:coverage",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && lefthook install || true"
  },
  "devDependencies": {
    "lefthook": "^2.1.1"
  }
}
