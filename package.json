{
  "name": "voyager",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter @voyager/shared-types build && pnpm --filter voyager-server build && pnpm --filter voyager-web build",
    "lint": "eslint --config eslint.config.js .",
    "lint:fix": "eslint --config eslint.config.js . --fix",
    "format": "prettier --config prettier.config.mjs --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --config prettier.config.mjs --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "pnpm --filter voyager-server run test",
    "test:coverage": "pnpm --filter voyager-server run test:coverage",
    "test:integration": "pnpm --filter voyager-server run test:integration",
    "test:e2e": "pnpm --dir apps/client/web exec playwright test --config=../../../playwright.config.ts",
    "test:e2e:fast": "pnpm --dir apps/client/web exec playwright test --config=../../../playwright.config.ts --grep @fast --project=chromium",
    "test:e2e:real": "pnpm --dir apps/client/web exec playwright test --config=../../../playwright.real.config.ts",
    "seed:test": "npx tsx scripts/seed-test-db.ts",
    "test:smoke": "bash scripts/smoke-test.sh",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && lefthook install || true",
    "eval": "pnpm --filter voyager-eval run eval",
    "eval:adversarial": "pnpm --filter voyager-eval run eval:adversarial"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@trivago/prettier-plugin-sort-imports": "^4",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3",
    "eslint-plugin-unused-imports": "^4",
    "globals": "^15",
    "lefthook": "^2.1.1",
    "prettier": "^3",
    "typescript-eslint": "^8"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "^8.3.1",
      "lodash": "^4.17.21",
      "brace-expansion@>=4.0.0 <5.0.5": "^5.0.5"
    }
  }
}
